# Dependencies
node_modules/

# Build / cache
*.tsbuildinfo
.DS_Store

# Bebop runtime state (NEVER commit your local memory / vault / sync DB)
.bebop/
memory.json
*.vault.json
*.sqlite
*.db

# Logs
