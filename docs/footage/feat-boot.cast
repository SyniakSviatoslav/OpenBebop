[1.270296, "o", "\u001b[2m  boot | init [--preset bebop|--json {...}] | status | agents | use <backend>\u001b[0m\r\n\u001b[2m  run [doer|reason|redline] | dispatch \"<task>\" | route <class> | recall <query>\u001b[0m\r\n\u001b[2m  govern \"<q,..>\" | self [maintain|evolve|session|loop] | node | sync [--port N]\u001b[0m\r\n\u001b[2m  map [module] | diagrams | mcp | help\u001b[0m\r\n"]
