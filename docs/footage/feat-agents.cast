[1.176687, "o", "\u001b[38;2;70;176;164m◈\u001b[0m \u001b[1m\u001b[38;2;242;233;219mBebop\u001b[0m\u001b[0m \u001b[2m— your kitchen, your ship, your cut.\u001b[0m\r\n\u001b[2m  Bebop drives ANY connected agentic CLI. Switch directly with:  bebop use <name>\u001b[0m\r\n"]
[1.178628, "o", "\u001b[2m  · free      \u001b[38;2;70;176;164m◆ default\u001b[0m  \u001b[2mFree LLM (OpenRouter free tier)\u001b[0m  key: OPENROUTER_API_KEY/OPENROUTER_FREE_KEY\u001b[0m\r\n"]
[1.182593, "o", "\u001b[2m  · opencode  \u001b[38;2;232;165;68m○ available (needs key/binary)\u001b[0m  \u001b[2mOpenCode\u001b[0m  key: ANTHROPIC_API_KEY/OPENAI_API_KEY/OPENROUTER_API_KEY/GOOGLE_GENERATIVE_AI_API_KEY/GEMINI_API_KEY\u001b[0m\r\n"]
[1.186242, "o", "\u001b[2m  · codex     \u001b[38;2;232;165;68m○ available (needs key/binary)\u001b[0m  \u001b[2mCodex CLI\u001b[0m  key: OPENAI_API_KEY/CODEX_API_KEY\u001b[0m\r\n"]
[1.189969, "o", "\u001b[2m  · claude    \u001b[38;2;232;165;68m○ available (needs key/binary)\u001b[0m  \u001b[2mClaude Code\u001b[0m  key: ANTHROPIC_API_KEY\u001b[0m\r\n"]
[1.193597, "o", "\u001b[2m  · hermes    \u001b[38;2;232;165;68m○ available (needs key/binary)\u001b[0m  \u001b[2mHermes\u001b[0m  key: ANTHROPIC_API_KEY/GOOGLE_API_KEY/GEMINI_API_KEY/OPENROUTER_API_KEY\u001b[0m\r\n"]
[1.197139, "o", "\u001b[2m  · aider     \u001b[38;2;232;165;68m○ available (needs key/binary)\u001b[0m  \u001b[2mAider\u001b[0m  key: ANTHROPIC_API_KEY/OPENAI_API_KEY/OPENROUTER_API_KEY/GEMINI_API_KEY/DEEPSEEK_API_KEY\u001b[0m\r\n"]
