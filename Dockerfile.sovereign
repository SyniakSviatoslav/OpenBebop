# Bebop Sovereign Node — Phase 1: Offline OCI (air-gapped, client-owned box)
#
# Operator directive (2026-07-08): package bebop as a self-contained Sovereign Node for a B2B
# client's own hardware. No OpenAI/Anthropic egress. The deterministic core is the wasm32
# bebop_core.wasm kernel (already built by crates/core/build.sh); the LLM periphery is a LOCAL
# model via Ollama (CPU-capable small models; GPU optional). Ship as `docker save` tarball / USB.
#
# This is a NEW parallel artifact. Prod `Dockerfile` + Fly deploy are untouched (ship discipline:
# sovereign node is feature-flagged, default off).

# ---- Stage 1: build the wasm kernel (proven real target) -------------------------------
FROM rust:1-slim AS core-builder
RUN rustup target add wasm32-unknown-unknown
WORKDIR /core
COPY crates/core ./
RUN bash build.sh && ls -la /core/../src/bebop_core.wasm 2>/dev/null; \
    # build.sh copies into its own ../src; re-copy explicitly to a known layer
    mkdir -p /artifacts && cp target/wasm32-unknown-unknown/release/bebop_core.wasm /artifacts/

# ---- Stage 2: node runtime (the TS agent shell) ----------------------------------------
FROM node:22-slim AS runtime
WORKDIR /app

# Install pnpm (bebop uses pnpm in dev; we pin for reproducibility)
RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.json ./
COPY src ./src
COPY llm-manifest.json ./llm-manifest.json 2>/dev/null || true
# The deterministic kernel artifact from the core build
COPY --from=core-builder /artifacts/bebop_core.wasm ./src/bebop_core.wasm

# Install ONLY runtime deps (no dev/test toolchain in the sovereign box)
RUN pnpm install --frozen-lockfile --prod || pnpm install --prod

# ---- Stage 3: Ollama sidecar (local LLM, no external egress) ---------------------------
# Bound to 127.0.0.1 inside the compose network; never exposed publicly.
# CPU-only by default; set OLLAMA_GPU=1 + mount the nvidia runtime for CUDA (Phase 1+GPU option).

# ---- Final: the sovereign runtime image -------------------------------------------------
FROM runtime AS sovereign
ENV BEBOP_SOVEREIGN=1
ENV BEBOP_CORE_PATH=/app/src/bebop_core.wasm
ENV BEBOP_LLM_BASE_URL=http://ollama:11434
ENV BEBOP_LLM_MODEL=${BEBOP_LLM_MODEL:-qwen3-embedding:0.6b}
# Hard deny of external LLM egress: the shell MUST refuse any non-local base URL.
ENV BEBOP_ALLOW_EXTERNAL_LLM=0
# Telemetry stays local (no external push) in sovereign mode.
ENV BEBOP_TELEMETRY_SINK=local
ENTRYPOINT ["node", "bebop.ts"]
CMD ["boot"]
