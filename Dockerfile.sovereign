# Bebop Sovereign Node — Phase 1: Offline OCI (air-gapped, client-owned box)
#
# Operator directive (2026-07-08): package bebop as a self-contained Sovereign Node for a B2B
# client's own hardware. No OpenAI/Anthropic egress. The deterministic core is the wasm32
# bebop_core.wasm kernel (built by crates/core/build.sh); the LLM periphery is a LOCAL model via
# Ollama (CPU-capable small models; GPU optional). Ship as `docker save` tarball / USB.
#
# This is a NEW parallel artifact. Prod Dockerfile + Fly deploy are untouched (ship discipline:
# sovereign node is feature-flagged, default off).
#
# Build context root = bebop-repo/ (see .dockerignore). bebop uses npm (package-lock.json).

# ---- Stage 1: build the wasm kernel (proven real target) -------------------------------
FROM rust:1-slim AS core-builder
RUN rustup target add wasm32-unknown-unknown
WORKDIR /core
COPY crates/core ./
# build.sh compiles to wasm32-unknown-unknown and copies the artifact to /core/../src/bebop_core.wasm
RUN bash build.sh && ls -la /src/bebop_core.wasm

# ---- Stage 2: node runtime (the TS agent shell) ----------------------------------------
FROM node:22-slim AS runtime
WORKDIR /app

# Runtime deps only (no dev/test toolchain in the sovereign box). npm ci needs package-lock.json.
COPY package.json package-lock.json ./
COPY bebop.ts ./
COPY src ./src
COPY llm-manifest.json ./llm-manifest.json
# The deterministic kernel artifact from the core build (build.sh wrote it to /src).
COPY --from=core-builder /src/bebop_core.wasm ./src/bebop_core.wasm

RUN npm ci --omit=dev || npm install --omit=dev

# ---- Final: the sovereign runtime image -------------------------------------------------
FROM runtime AS sovereign
ENV BEBOP_SOVEREIGN=1
ENV BEBOP_CORE_PATH=/app/src/bebop_core.wasm
ENV BEBOP_LLM_BASE_URL=http://ollama:11434
ENV BEBOP_LLM_MODEL=${BEBOP_LLM_MODEL:-qwen3-embedding:0.6b}
# Hard deny of external LLM egress: the shell MUST refuse any non-local base URL.
ENV BEBOP_ALLOW_EXTERNAL_LLM=0
# Telemetry stays local (no external push) in sovereign mode.
ENV BEBOP_TELEMETRY_SINK=local
ENTRYPOINT ["node", "bebop.ts"]
CMD ["boot"]
